# TickerIO environment variables
# Copy to .env.local for development. NEVER commit real keys.
# All keys are server-side only (see CLAUDE.md §3 "Secrets only on the server").

# --- Market data (Phase 1) ---
MARKET_DATA_API_KEY=

# --- News (Phase 4) ---
NEWS_API_KEY=

# --- AI / LLM via Vercel AI SDK (Phase 4) ---
# Use whichever provider you wire up; default to a current Claude model.
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=

# --- Caching: Upstash Redis (Phase 4, Vercel Marketplace) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
